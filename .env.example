# Real Google Sheets integration settings
# 1. Create a Google Cloud API key with Sheets API enabled
# 2. Make your spreadsheet readable by the API key (public or link-sharing as needed)
# 3. Copy the spreadsheet ID from the sheet URL

VITE_GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
VITE_GOOGLE_SHEETS_API_KEY=your_google_api_key_here
VITE_GOOGLE_SHEETS_OWNER_RANGE=Owners!A2:I

# Gmail SMTP settings for OTP delivery
# Use an App Password for Gmail accounts with 2FA enabled.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Ruby VP Scheduler <your@gmail.com>"
